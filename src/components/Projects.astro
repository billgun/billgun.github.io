---
const projects = [
  {
    title: 'Project One',
    description: 'A short description of what this project does and the problem it solves.',
    tags: ['React', 'Node.js', 'PostgreSQL'],
    color: 'var(--color-yellow)',
    emoji: '🛒',
    link: '#',
    repo: '#',
  },
  {
    title: 'Project Two',
    description: 'A short description of what this project does and the problem it solves.',
    tags: ['Astro', 'Tailwind'],
    color: 'var(--color-teal)',
    emoji: '📊',
    link: '#',
    repo: '#',
  },
  {
    title: 'Project Three',
    description: 'A short description of what this project does and the problem it solves.',
    tags: ['TypeScript', 'API'],
    color: 'var(--color-pink)',
    emoji: '🎮',
    link: '#',
    repo: '#',
  },
];
---

<section id="projects" class="projects">
  <div class="container">
    <p class="eyebrow">Selected work</p>
    <h2 class="section-title">Projects I'm proud of</h2>
    <p class="section-sub">
      Replace these with your real projects — name, description, tags, and links.
    </p>
    <div class="projects-grid">
      {projects.map((p) => (
        <div class="project-card">
          <div class="project-thumb" style={`background:${p.color}`}>{p.emoji}</div>
          <h3>{p.title}</h3>
          <p>{p.description}</p>
          <div class="tags">
            {p.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          <div class="project-links">
            <a href={p.link}>Live demo →</a>
            <a href={p.repo}>Code →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
  }
  .project-card {
    border: 3px solid var(--color-text);
    border-radius: var(--radius);
    background: #fff;
    padding: 22px;
    box-shadow: var(--shadow);
    transition: transform 0.15s ease;
  }
  .project-card:hover {
    transform: translateY(-5px);
  }
  .project-thumb {
    width: 100%;
    height: 140px;
    border-radius: 12px;
    border: 3px solid var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    margin-bottom: 18px;
  }
  .project-card h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
  }
  .project-card p {
    color: #5c5470;
    font-size: 0.95rem;
    margin-bottom: 16px;
  }
  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .tag {
    font-size: 0.78rem;
    font-weight: 700;
    background: #f1ebff;
    color: var(--color-purple);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .project-links {
    display: flex;
    gap: 16px;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .project-links a:hover {
    color: var(--color-coral);
  }
  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
