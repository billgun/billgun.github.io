---
const projects = [
  {
    title: "Project One",
    description:
      "A short description of what this project does and the problem it solves.",
    tags: ["React", "Node.js", "PostgreSQL"],
    color: "bg-yellow",
    emoji: "🛒",
    link: "#",
    repo: "#",
  },
  {
    title: "Project Two",
    description:
      "A short description of what this project does and the problem it solves.",
    tags: ["Astro", "Tailwind"],
    color: "bg-teal",
    emoji: "📊",
    link: "#",
    repo: "#",
  },
  {
    title: "Project Three",
    description:
      "A short description of what this project does and the problem it solves.",
    tags: ["TypeScript", "API"],
    color: "bg-pink",
    emoji: "🎮",
    link: "#",
    repo: "#",
  },
];
---

<section id="projects">
  <div class="container">
    <p class="eyebrow">Selected work</p>

    <h2 class="section-title">Projects I'm proud of</h2>

    <p class="section-sub">
      Replace these with your real projects — name, description, tags, and
      links.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        projects.map((p) => (
          <div class="border-ink rounded-card shadow-pop border-[3px] bg-white p-5 transition-transform hover:-translate-y-1.5">
            <div
              class={`border-ink mb-4 flex h-[140px] w-full items-center justify-center rounded-xl border-[3px] text-5xl ${p.color}`}
            >
              {p.emoji}
            </div>

            <h3 class="mb-2 text-[1.25rem]">{p.title}</h3>

            <p class="mb-4 text-[0.95rem] text-[#5c5470]">{p.description}</p>

            <div class="mb-4 flex flex-wrap gap-2">
              {p.tags.map((t) => (
                <span class="text-purple rounded-full bg-[#f1ebff] px-2.5 py-1 text-[0.78rem] font-bold">
                  {t}
                </span>
              ))}
            </div>

            <div class="flex gap-4 text-[0.9rem] font-bold">
              <a href={p.link} class="hover:text-coral transition-colors">
                Live demo →
              </a>

              <a href={p.repo} class="hover:text-coral transition-colors">
                Code →
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
