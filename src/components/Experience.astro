---
const items = [
  {
    role: "Fullstack Software Engineer",
    org: "PT. HFX Internasional Berjangka",
    period: "Aug 2025 - Present",
    desc: "Building real-time stock trading features with WebSocket, Next.js, Express.js & MongoDB, integrating Alpaca, TradingView, and Polygon.io for 1,000+ active users.",
  },
  {
    role: "Fullstack Software Engineer",
    org: "EBUDDY PTE. LTD.",
    period: "Apr 2024 - Feb 2025",
    desc: "Designed scalable web apps with Next.js & Express.js, implemented Figma designs directly, and led the migration from multi-repo to monorepo using Turborepo.",
  },
  {
    role: "Technical Lead",
    org: "Ifabula Digital Kreasi",
    period: "Jan 2020 - Jan 2023",
    desc: "Led a team of engineers, served as the primary technical escalation point, and worked with stakeholders to define project scope and technical strategy.",
  },
  {
    role: "Outsystems Developer",
    org: "Ifabula Digital Kreasi",
    period: "Nov 2018 - Dec 2019",
    desc: "Designed scalable web and mobile apps on the Outsystems platform, integrated third-party APIs, and provided end-user training.",
  },
  {
    role: "B.Sc. in Informatics",
    org: "Universitas Tanjungpura",
    period: "Aug 2014 - Nov 2018",
    desc: "Focus on Java, Data Structures, Algorithms, and Database Management. Graduated with honors.",
  },
];

const certs = [
  "AWS Certified Cloud Practitioner - AWS (2024–2027)",
  "Mobile Developer Specialist - Outsystems (2019)",
  "Associate Reactive Developer - Outsystems (2019)",
  "JLPT N4 - The Japan Foundation (2025)",
];
---

<section id="experience">
  <div class="container">
    <p class="eyebrow">Journey so far</p>

    <h2 class="section-title">Experience</h2>

    <p class="section-sub">A quick timeline of where I've been.</p>

    <div class="border-ink relative border-l-[3px] border-dashed pl-7.5">
      {
        items.map((item) => (
          <div class="relative mb-10 last:mb-0">
            <div class="bg-coral border-ink absolute top-1 -left-[39px] h-4 w-4 rounded-full border-[3px]" />

            <span class="text-purple text-[0.8rem] font-bold tracking-wide uppercase">
              {item.period}
            </span>

            <h3 class="mt-1.5 mb-0.5 text-[1.2rem]">{item.role}</h3>

            <p class="mb-2 font-semibold text-[#5c5470]">{item.org}</p>

            <p class="max-w-[560px] text-[#5c5470]">{item.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="border-ink mt-15 border-t-[3px] border-dashed pt-10">
      <h3 class="mb-4 text-[1.3rem]">Certifications</h3>

      <ul class="m-0 grid list-none gap-2.5 p-0">
        {
          certs.map((c) => (
            <li class="relative pl-6 text-[#5c5470] before:absolute before:left-0 before:content-['🏅']">
              {c}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
