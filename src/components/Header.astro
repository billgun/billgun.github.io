---
const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class="bg-bg/85 border-ink sticky top-0 z-50 border-b-[3px] backdrop-blur-md"
>
  <div class="container flex items-center justify-between py-4">
    <a href="/" class="font-heading text-[1.3rem] font-bold"
      >billy<span class="text-coral">.dev</span></a
    >
    <nav class="hidden gap-7 font-semibold md:flex">
      {
        links.map((link) => (
          <a href={link.href} class="hover:text-purple transition-colors">
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="btn hidden px-5 py-2.5 text-[0.9rem] md:inline-flex">Say hi 👋</a
    >
    <button
      class="cursor-pointer border-none bg-none text-2xl md:hidden"
      id="menu-btn"
      aria-label="Open menu">☰</button
    >
  </div>
  <nav
    class="border-ink hidden flex-col gap-3.5 border-t-2 border-dashed px-6 pt-4 pb-5 font-semibold"
    id="mobile-nav"
  >
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
  </nav>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const nav = document.getElementById("mobile-nav");
  btn?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");
    nav?.classList.toggle("flex");
  });
  nav?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      nav.classList.add("hidden");
      nav.classList.remove("flex");
    }),
  );
</script>
