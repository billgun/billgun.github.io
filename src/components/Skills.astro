---
const skills = [
  { name: "JavaScript / TypeScript", icon: "🟨" },
  { name: "Next.js / React", icon: "⚛️" },
  { name: "Node.js / Express.js", icon: "🟢" },
  { name: "Java", icon: "☕" },
  { name: "Tailwind CSS / SCSS", icon: "🎨" },
  { name: "MongoDB / PostgreSQL / MySQL", icon: "🗄️" },
  { name: "Supabase / AWS S3", icon: "☁️" },
  { name: "WebSocket", icon: "🔌" },
  { name: "Turborepo / Monorepo", icon: "📦" },
  { name: "Git & CI/CD", icon: "🐙" },
  { name: "Figma to code", icon: "🎯" },
  { name: "Trading APIs (Alpaca, TradingView, Polygon.io)", icon: "📈" },
];
const colors = [
  "border-coral",
  "border-teal",
  "border-purple",
  "border-yellow",
];
---

<section id="skills">
  <div class="container">
    <p class="eyebrow">What I work with</p>
    <h2 class="section-title">Tools & technologies</h2>
    <p class="section-sub">
      The stack I reach for most often when building things.
    </p>
    <div class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 md:grid-cols-3">
      {
        skills.map((skill, i) => (
          <div
            class={`flex items-center gap-3 border-[3px] px-5 py-[18px] ${colors[i % colors.length]} shadow-pop rounded-2xl bg-white font-semibold transition-transform hover:-translate-y-1`}
          >
            <span class="text-[1.4rem]">{skill.icon}</span>
            <span>{skill.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
