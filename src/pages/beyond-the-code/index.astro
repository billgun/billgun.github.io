---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";
import { getRawgGame } from "@/lib/rawg";

const streamLinks = [
  { label: "Twitch", href: "https://twitch.tv/your-handle", icon: "🟣" },
  { label: "YouTube", href: "https://youtube.com/@your-handle", icon: "🔴" },
];

const interests = [
  {
    title: "Gaming & Streaming",
    icon: "🎮",
    color: "bg-coral",
    desc: "I've been gaming way longer than I've been writing code. These days I split free time between ranked grinds and streaming for fun — same focus, different keyboard shortcuts.",
  },
  {
    title: "Final Fantasy XIV",
    icon: "⚔️",
    color: "bg-teal",
    desc: "My current main game. I tinker with Dalamud plugins on the side too — basically modding my own client, which scratches the same itch as side-project coding.",
  },
  {
    title: "Indie Game Dev",
    icon: "🛠️",
    color: "bg-yellow",
    desc: "I build small incremental games in Godot (C#) as a side creative outlet — full progression systems, skill trees, the works. It's coding, but the payoff is a game instead of a deploy.",
  },
  {
    title: "Japanese Language",
    icon: "🇯🇵",
    color: "bg-purple",
    desc: "Passed JLPT N4 and still actively learning — partly to read games and manga in their original language, partly because I just enjoy the process.",
  },
];

const allGames = await getCollection("games");

const gamesWithCovers = await Promise.all(
  allGames.map(async (game) => {
    const rawg = await getRawgGame(game.data.rawgSlug);
    const { Content } = await render(game);
    return { ...game, rawg, Content };
  }),
);

const statusOrder = { playing: 0, finished: 1, dropped: 2 } as const;
gamesWithCovers.sort((a, b) => {
  const statusDiff = statusOrder[a.data.status] - statusOrder[b.data.status];
  if (statusDiff !== 0) return statusDiff;
  const aDate = a.data.finishedDate ?? a.data.startedDate ?? new Date(0);
  const bDate = b.data.finishedDate ?? b.data.startedDate ?? new Date(0);
  return bDate.valueOf() - aDate.valueOf();
});

const statusLabel: Record<string, string> = {
  playing: "🎮 Currently Playing",
  finished: "✅ Finished",
  dropped: "🚫 Dropped",
};

const statusBorder: Record<string, string> = {
  playing: "border-teal",
  finished: "border-coral",
  dropped: "border-purple",
};
---

<Layout
  title="Beyond the Code — Billy Gunawan"
  description="Get to know Billy outside of work: gaming, streaming, Final Fantasy XIV, indie game dev, and learning Japanese."
>
  <Header />

  <section class="relative overflow-hidden pt-25 pb-16">
    <div class="blob bg-yellow -top-16 -right-12 h-72 w-72"></div>
    <div class="relative z-10 container max-w-180">
      <p class="eyebrow">Off the clock</p>
      <h1 class="mb-6 text-[clamp(2rem,5vw,3.2rem)]">Beyond the code</h1>
      <p class="max-w-140 text-[1.1rem] text-[#5c5470]">
        Work is only part of the story. Here's what I'm into when I'm not
        shipping features — mostly games, streaming, and a few nerdy side
        quests.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          interests.map((item) => (
            <div class="border-ink rounded-card shadow-pop border-[3px] bg-white p-6">
              <div
                class={`border-ink mb-4 flex h-14 w-14 items-center justify-center rounded-2xl border-[3px] text-2xl ${item.color}`}
              >
                {item.icon}
              </div>
              <h3 class="mb-2 text-[1.25rem]">{item.title}</h3>
              <p class="text-[#5c5470]">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">Game log</p>
      <h2 class="section-title">Games I've played</h2>
      <p class="section-sub">
        What I'm currently grinding, what I finished, and what I bounced off of
        — with honest takes on each.
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          gamesWithCovers.map(({ data, rawg, Content }) => (
            <div
              class={`border-[3px] ${statusBorder[data.status]} rounded-card shadow-pop flex flex-col overflow-hidden bg-white`}
            >
              <div class="border-ink flex h-40 w-full items-center justify-center overflow-hidden border-b-[3px] bg-[#f1ebff]">
                {rawg?.backgroundImage ? (
                  <img
                    src={rawg.backgroundImage}
                    alt={data.title}
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <span class="text-4xl">🎮</span>
                )}
              </div>
              <div class="flex flex-1 flex-col p-5">
                <span class="text-purple mb-1 text-[0.78rem] font-bold tracking-wide uppercase">
                  {statusLabel[data.status]}
                </span>
                <h3 class="mb-1 text-[1.15rem]">{data.title}</h3>
                {data.rating && (
                  <p class="text-coral mb-2 text-[0.9rem] font-bold">
                    ⭐ {data.rating}/10
                  </p>
                )}
                <div class="prose-sm mb-3 text-[0.92rem] text-[#5c5470] [&_p]:mb-2">
                  <Content />
                </div>
                <div class="mt-auto border-t border-dashed border-[#ddd] pt-2 text-[0.78rem] text-[#8a8298]">
                  {data.startedDate && (
                    <span>
                      Started{" "}
                      {data.startedDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                      })}
                    </span>
                  )}
                  {data.finishedDate && (
                    <span>
                      {" "}
                      — {data.status === "dropped"
                        ? "Dropped"
                        : "Finished"}{" "}
                      {data.finishedDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                      })}
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="blob bg-teal -top-12 -right-10 h-60 w-60" style="opacity: 0.3;">
    </div>
    <div class="relative z-10 container max-w-170">
      <p class="eyebrow">Catch me live</p>
      <h2 class="section-title">Find me gaming or streaming</h2>
      <p class="section-sub">
        Drop by, say hi, or just lurk — either way works for me.
      </p>
      <div class="flex flex-wrap gap-3.5">
        {
          streamLinks.map((l) => (
            <a
              href={l.href}
              target="_blank"
              rel="noopener"
              class="btn secondary"
            >
              <span>{l.icon}</span> {l.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>
