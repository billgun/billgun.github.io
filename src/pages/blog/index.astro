---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog — Bill Gunawan" description="Writing on web dev, projects, and things I'm learning.">
  <Header />
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1 class="section-title">Blog</h1>
      <p class="section-sub">Notes on projects, code, and whatever else I'm into lately.</p>
    </div>
  </section>
  <section class="blog-list">
    <div class="container">
      {posts.length === 0 && <p>No posts yet — check back soon!</p>}
      <div class="posts-grid">
        {posts.map((post) => {
          const date = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a href={`/blog/${post.id}`} class="post-card">
              <p class="post-card-date">{date}</p>
              <h2>{post.data.title}</h2>
              {post.data.description && <p class="post-card-desc">{post.data.description}</p>}
              {post.data.tags && (
                <div class="post-card-tags">
                  {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
                </div>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .blog-hero {
    padding-bottom: 40px;
  }
  .blog-list {
    padding-top: 0;
  }
  .posts-grid {
    display: grid;
    gap: 22px;
    max-width: 700px;
  }
  .post-card {
    display: block;
    border: 3px solid var(--color-text);
    border-radius: var(--radius);
    background: #fff;
    padding: 26px 28px;
    box-shadow: var(--shadow);
    transition: transform 0.15s ease;
  }
  .post-card:hover {
    transform: translateY(-3px);
  }
  .post-card-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-purple);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }
  .post-card h2 {
    font-size: 1.4rem;
    margin-bottom: 8px;
  }
  .post-card-desc {
    color: #5c5470;
    margin-bottom: 14px;
  }
  .post-card-tags {
    display: flex;
    gap: 8px;
  }
  .tag {
    font-size: 0.78rem;
    font-weight: 700;
    background: #f1ebff;
    color: var(--color-purple);
    padding: 4px 10px;
    border-radius: 999px;
  }
</style>
