---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Bill Gunawan`} description={description}>
  <Header />
  <article class="post">
    <div class="container post-container">
      <a href="/blog" class="back-link">← Back to blog</a>
      <p class="post-date">{formattedDate}</p>
      <h1 class="post-title">{title}</h1>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      <div class="post-content">
        <slot />
      </div>
    </div>
  </article>
  <Footer />
</Layout>

<style>
  .post {
    padding: 60px 0 100px;
  }
  .post-container {
    max-width: 700px;
  }
  .back-link {
    display: inline-block;
    font-weight: 700;
    color: var(--color-purple);
    margin-bottom: 30px;
  }
  .back-link:hover {
    color: var(--color-coral);
  }
  .post-date {
    font-size: 0.85rem;
    font-weight: 700;
    color: #8a8298;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 10px;
  }
  .post-title {
    font-size: clamp(2rem, 4vw, 2.6rem);
    margin-bottom: 18px;
  }
  .post-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 36px;
  }
  .tag {
    font-size: 0.78rem;
    font-weight: 700;
    background: #f1ebff;
    color: var(--color-purple);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .post-content {
    font-size: 1.05rem;
    color: #2c2440;
  }
  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 40px 0 16px;
  }
  .post-content :global(h3) {
    font-size: 1.2rem;
    margin: 30px 0 12px;
  }
  .post-content :global(p) {
    margin: 0 0 18px;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 18px;
    padding-left: 24px;
  }
  .post-content :global(li) {
    margin-bottom: 8px;
  }
  .post-content :global(a) {
    color: var(--color-coral);
    text-decoration: underline;
  }
  .post-content :global(code) {
    background: #f1ebff;
    padding: 2px 6px;
    border-radius: 6px;
    font-size: 0.9em;
  }
  .post-content :global(pre) {
    background: #1f1633;
    color: #f5f3ff;
    padding: 18px;
    border-radius: 12px;
    overflow-x: auto;
    margin-bottom: 18px;
  }
  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-yellow);
    padding-left: 18px;
    color: #5c5470;
    margin: 0 0 18px;
  }
  .post-content :global(img) {
    border-radius: 14px;
    border: 3px solid var(--color-text);
    margin: 24px 0;
  }
</style>
