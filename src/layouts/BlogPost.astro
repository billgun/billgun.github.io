---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const updatedFormatted = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} — Billy Gunawan`} description={description}>
  <Header />

  <article class="py-16 pb-24">
    <div class="container max-w-[720px]">
      <a
        href="/blog"
        class="text-purple hover:text-coral mb-10 inline-flex items-center gap-1.5 font-bold transition-colors"
      >
        <Icon name="tabler:arrow-left" class="h-4 w-4" />
        Back to blog
      </a>

      {
        heroImage && (
          <div class="rounded-card border-ink shadow-pop mb-8 w-full overflow-hidden border-[3px]">
            <img
              src={heroImage}
              alt={title}
              class="max-h-[420px] w-full object-cover"
            />
          </div>
        )
      }

      <p
        class="mb-2 text-[0.82rem] font-bold tracking-wide text-[#8a8298] uppercase"
      >
        {formattedDate}
        {
          updatedFormatted && (
            <span class="ml-2 text-[#b0aabb]">
              · Updated {updatedFormatted}
            </span>
          )
        }
      </p>

      <h1 class="mb-4 text-[clamp(2rem,4vw,2.6rem)]">{title}</h1>

      {
        description && (
          <p class="mb-5 text-[1.05rem] text-[#5c5470]">{description}</p>
        )
      }

      {
        tags.length > 0 && (
          <div class="mb-10 flex flex-wrap gap-2">
            {tags.map((t) => (
              <a
                href={`/blog?tag=${t}`}
                class="text-purple hover:bg-purple rounded-full bg-[#f1ebff] px-2.5 py-1 text-[0.78rem] font-bold transition-colors hover:text-white"
              >
                {t}
              </a>
            ))}
          </div>
        )
      }

      <div
        class="prose prose-lg prose-headings:font-heading prose-headings:text-ink prose-h2:text-[1.5rem] prose-h3:text-[1.2rem] prose-p:text-[#2c2440] prose-p:leading-[1.8] prose-a:text-coral prose-a:underline prose-a:underline-offset-[3px] prose-a:no-underline hover:prose-a:text-purple prose-code:text-purple prose-code:bg-[#f1ebff] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:font-normal prose-code:before:content-none prose-code:after:content-none prose-pre:bg-[#1f1633] prose-pre:text-[#f5f3ff] prose-pre:border-[3px] prose-pre:border-ink prose-pre:rounded-2xl prose-blockquote:border-l-yellow prose-blockquote:border-l-4 prose-blockquote:text-[#5c5470] prose-blockquote:italic prose-blockquote:not-italic prose-img:rounded-2xl prose-img:border-[3px] prose-img:border-ink prose-img:shadow-pop prose-th:bg-[#f1ebff] prose-th:font-bold prose-hr:border-dashed prose-hr:opacity-20 max-w-none"
      >
        <slot />
      </div>
    </div>
  </article>

  <Footer />
</Layout>
